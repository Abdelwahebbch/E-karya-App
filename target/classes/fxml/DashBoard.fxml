<VBox maxHeight="600" minHeight="600" prefHeight="600" spacing="10" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ekarya.controller.DashBoardController">
    <!-- Top Navigation Bar -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: white; -fx-padding: 10;" stylesheets="@../styles/homePage.css">
        <ImageView fitHeight="40" fitWidth="40">
            <Image url="@../images/Logo.jpg" />
        </ImageView>

        <Region prefHeight="40.0" prefWidth="388.0" HBox.hgrow="ALWAYS" />
        <MenuButton text="Menu">
            <items>
                <MenuItem text="Réservations" />
                <MenuItem text="Revenus" />
            <MenuItem text="Créer une annonce" />
            <MenuItem text="Logout" />
            </items>
        </MenuButton>
    </HBox>

    <!-- Search Section -->
    <HBox alignment="CENTER" spacing="10" style="-fx-padding: 20;">
        <VBox style="-fx-background-color: white; -fx-background-radius: 25; -fx-border-radius: 25; -fx-border-color: #ddd; -fx-padding: 5 15;">
            <HBox alignment="CENTER" spacing="15">
                <VBox spacing="5">
               <children>
                  <Hyperlink text="Massages" />
               </children>
                </VBox>

                <Separator orientation="VERTICAL" />
            <Hyperlink text="Mes Annonces" />

                <VBox spacing="5" />

                <Separator orientation="VERTICAL" />
            <TextField promptText="Search By House name " />

                <VBox spacing="5" />

                <Separator orientation="VERTICAL" />

                <VBox spacing="5" />

                <Button prefHeight="28.0" prefWidth="60.0" style="-fx-background-color: #FF385C; -fx-text-fill: white; -fx-background-radius: 50;">
                    <graphic>
                        <ImageView fitHeight="20" fitWidth="20">
                            <Image url="@../images/search.png" />
                        </ImageView>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </HBox>

    <!-- Listings Grid -->
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
        <GridPane hgap="20" style="-fx-padding: 20;" vgap="20">
            <columnConstraints>
                <ColumnConstraints percentWidth="33" />
                <ColumnConstraints percentWidth="33" />
                <ColumnConstraints percentWidth="33" />
            </columnConstraints>

            <!-- Listing Card 1 -->
            <VBox onMouseClicked="#handleListingClick" style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #ddd; -fx-cursor: hand;" styleClass="clickable-listing" userData="listing_1" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <ImageView fitHeight="200" fitWidth="286.0" onMouseClicked="#handleListingClick">
                    <Image url="@../images/House.jpg" />
                </ImageView>
                <VBox spacing="5" style="-fx-padding: 10;">
                    <HBox spacing="10">
                        <Text style="-fx-font-weight: bold;" text="Maison 1" />
                        <Text text="★ 4,96" />
                    </HBox>
                    <Text text="Séjournez chez Annie" />
                    <Text text="1-6 mars" />
                    <Text style="-fx-font-weight: bold;" text="104 € par nuit" />
                </VBox>
            </VBox>
